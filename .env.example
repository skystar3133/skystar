# 하늘별컴퓨터교습소 환경설정 예제
# 이 파일을 .env로 복사하고 필요에 따라 수정하세요.

# 웹사이트 설정
SITE_NAME=하늘별컴퓨터교습소
SITE_URL=https://skystar3133.github.io/skystar
SITE_LANG=ko

# 연락처 정보
PHONE=010-XXXX-XXXX
EMAIL=contact@example.com
ADDRESS=서울시 강남구 테헤란로 123

# 학원 정보
ACADEMY_YEAR_ESTABLISHED=2004
INSTRUCTOR_EXPERIENCE=20

# 서버 설정
NODE_ENV=production
PORT=3000

# 데이터베이스 (선택사항)
DATABASE_URL=

# API 설정
API_KEY=
API_SECRET=

# 소셜 미디어
KAKAO_TALK_URL=https://open.kakao.com/o/syNnsvCh
NAVER_MAP_URL=https://naver.me/GP2XJ6uU

# 분석 도구
GOOGLE_ANALYTICS_ID=
NAVER_ANALYTICS_ID=

# 이메일 설정
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# 파일 업로드
UPLOAD_DIR=/uploads
MAX_FILE_SIZE=10485760

# 캐시 설정
CACHE_TTL=3600
SESSION_TTL=86400

# 보안
JWT_SECRET=
CSRF_TOKEN=

# 개발 설정
DEBUG=false
LOG_LEVEL=info

# Supabase 설정 (API 키는 절대 공개하지 말 것)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_api_key_here
